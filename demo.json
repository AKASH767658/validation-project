{
  "field_schema": [
    {
      "key": "planName",
      "label": "401(k) Plan Name",
      "type": "text",
      "options": null,
      "format": null
    },
    {
      "key": "planNumber",
      "label": "401(k) Plan Number",
      "type": "text",
      "options": null,
      "format": "###"
    },
    {
      "key": "employerLegalName",
      "label": "Employer Legal Name",
      "type": "text",
      "options": null,
      "format": null
    },
    {
      "key": "employerEin",
      "label": "Employer EIN",
      "type": "text",
      "options": null,
      "format": "##-#######"
    },
    {
      "key": "planEffectiveDate",
      "label": "Plan Effective Date",
      "type": "date",
      "options": null,
      "format": "MM/DD/YYYY"
    },
    {
      "key": "contributionType",
      "label": "Contribution Type",
      "type": "enum_single",
      "options": [
        "Traditional Pre-Tax",
        "Roth After-Tax",
        "Traditional and Roth",
        "Employer Only",
        "Safe Harbor"
      ],
      "format": null
    },
    {
      "key": "employeeContributionPercentage",
      "label": "Employee Contribution Percentage",
      "type": "percentage",
      "options": null,
      "format": "0.00%"
    },
    {
      "key": "employerMatchFormula",
      "label": "Employer Match Formula",
      "type": "text",
      "options": null,
      "format": null
    },
    {
      "key": "loanPermitted",
      "label": "Loan Permitted",
      "type": "boolean",
      "options": [
        "Yes",
        "No"
      ],
      "format": null
    },
    {
      "key": "automaticEnrollmentType",
      "label": "Automatic Enrollment Type",
      "type": "enum_single",
      "options": [
        "None",
        "Automatic Contribution Arrangement",
        "Eligible Automatic Contribution Arrangement",
        "Qualified Automatic Contribution Arrangement"
      ],
      "format": null
    },
    {
      "key": "defaultAutomaticEnrollmentPercentage",
      "label": "Default Automatic Enrollment Percentage",
      "type": "percentage",
      "options": null,
      "format": "0.00%"
    },
    {
      "key": "automaticAnnualIncreaseEnabled",
      "label": "Automatic Annual Increase Enabled",
      "type": "boolean",
      "options": [
        "Yes",
        "No"
      ],
      "format": null
    },
    {
      "key": "vestingSchedule",
      "label": "Vesting Schedule",
      "type": "enum_single",
      "options": [
        "Immediate Vesting",
        "3-Year Cliff",
        "6-Year Graded",
        "Custom Schedule"
      ],
      "format": null
    },
    {
      "key": "eligibilityRequirement",
      "label": "Eligibility Requirement",
      "type": "enum_single",
      "options": [
        "Immediate Eligibility",
        "30 Days of Service",
        "60 Days of Service",
        "90 Days of Service",
        "1 Year of Service",
        "Custom Eligibility"
      ],
      "format": null
    },
    {
      "key": "permittedWithdrawalTypes",
      "label": "Permitted Withdrawal Types",
      "type": "enum_multi",
      "options": [
        "Hardship Withdrawal",
        "In-Service Withdrawal",
        "Required Minimum Distribution",
        "Rollover Withdrawal",
        "Termination Distribution"
      ],
      "format": null
    }
  ],
  "dependency_rules": [
    {
      "id": "contribution-type-requires-employer-match",
      "description": "Employer match formula is required when contribution type includes employer or safe harbor contribution.",
      "when": {
        "field": "contributionType",
        "operator": "in",
        "value": [
          "Employer Only",
          "Safe Harbor",
          "Traditional and Roth"
        ]
      },
      "then": [
        {
          "action": "show",
          "fields": [
            "employerMatchFormula"
          ]
        },
        {
          "action": "require",
          "fields": [
            "employerMatchFormula"
          ]
        }
      ],
      "else": [
        {
          "action": "hide",
          "fields": [
            "employerMatchFormula"
          ]
        },
        {
          "action": "clearValue",
          "fields": [
            "employerMatchFormula"
          ]
        }
      ],
      "messages": {
        "employerMatchFormula": "Employer Match Formula is required when Contribution Type includes employer matching contribution."
      }
    },
    {
      "id": "automatic-enrollment-requires-default-percentage",
      "description": "Default automatic enrollment percentage is required when automatic enrollment type is not None.",
      "when": {
        "field": "automaticEnrollmentType",
        "operator": "notEquals",
        "value": "None"
      },
      "then": [
        {
          "action": "show",
          "fields": [
            "defaultAutomaticEnrollmentPercentage"
          ]
        },
        {
          "action": "require",
          "fields": [
            "defaultAutomaticEnrollmentPercentage"
          ]
        }
      ],
      "else": [
        {
          "action": "hide",
          "fields": [
            "defaultAutomaticEnrollmentPercentage"
          ]
        },
        {
          "action": "clearValue",
          "fields": [
            "defaultAutomaticEnrollmentPercentage"
          ]
        }
      ],
      "messages": {
        "defaultAutomaticEnrollmentPercentage": "Default Automatic Enrollment Percentage is required when Automatic Enrollment Type is selected."
      }
    },
    {
      "id": "annual-increase-requires-automatic-enrollment",
      "description": "Automatic annual increase is applicable only when automatic enrollment is enabled.",
      "when": {
        "field": "automaticEnrollmentType",
        "operator": "notEquals",
        "value": "None"
      },
      "then": [
        {
          "action": "show",
          "fields": [
            "automaticAnnualIncreaseEnabled"
          ]
        }
      ],
      "else": [
        {
          "action": "hide",
          "fields": [
            "automaticAnnualIncreaseEnabled"
          ]
        },
        {
          "action": "clearValue",
          "fields": [
            "automaticAnnualIncreaseEnabled"
          ]
        }
      ]
    },
    {
      "id": "custom-vesting-requires-custom-details",
      "description": "Custom vesting details are required when vesting schedule is Custom Schedule.",
      "when": {
        "field": "vestingSchedule",
        "operator": "equals",
        "value": "Custom Schedule"
      },
      "then": [
        {
          "action": "show",
          "fields": [
            "customVestingScheduleDetails"
          ]
        },
        {
          "action": "require",
          "fields": [
            "customVestingScheduleDetails"
          ]
        }
      ],
      "else": [
        {
          "action": "hide",
          "fields": [
            "customVestingScheduleDetails"
          ]
        },
        {
          "action": "clearValue",
          "fields": [
            "customVestingScheduleDetails"
          ]
        }
      ],
      "messages": {
        "customVestingScheduleDetails": "Custom Vesting Schedule Details are required when Vesting Schedule is Custom Schedule."
      }
    },
    {
      "id": "custom-eligibility-requires-custom-details",
      "description": "Custom eligibility details are required when eligibility requirement is Custom Eligibility.",
      "when": {
        "field": "eligibilityRequirement",
        "operator": "equals",
        "value": "Custom Eligibility"
      },
      "then": [
        {
          "action": "show",
          "fields": [
            "customEligibilityRequirementDetails"
          ]
        },
        {
          "action": "require",
          "fields": [
            "customEligibilityRequirementDetails"
          ]
        }
      ],
      "else": [
        {
          "action": "hide",
          "fields": [
            "customEligibilityRequirementDetails"
          ]
        },
        {
          "action": "clearValue",
          "fields": [
            "customEligibilityRequirementDetails"
          ]
        }
      ],
      "messages": {
        "customEligibilityRequirementDetails": "Custom Eligibility Requirement Details are required when Eligibility Requirement is Custom Eligibility."
      }
    },
    {
      "id": "loan-permitted-dependent-fields",
      "description": "Loan-related fields are required when loans are permitted.",
      "when": {
        "field": "loanPermitted",
        "operator": "equals",
        "value": "Yes"
      },
      "then": [
        {
          "action": "show",
          "fields": [
            "maximumLoanAmount",
            "minimumLoanAmount",
            "loanRepaymentPeriod"
          ]
        },
        {
          "action": "require",
          "fields": [
            "maximumLoanAmount",
            "loanRepaymentPeriod"
          ]
        }
      ],
      "else": [
        {
          "action": "hide",
          "fields": [
            "maximumLoanAmount",
            "minimumLoanAmount",
            "loanRepaymentPeriod"
          ]
        },
        {
          "action": "clearValue",
          "fields": [
            "maximumLoanAmount",
            "minimumLoanAmount",
            "loanRepaymentPeriod"
          ]
        }
      ],
      "messages": {
        "maximumLoanAmount": "Maximum Loan Amount is required when Loan Permitted is Yes.",
        "loanRepaymentPeriod": "Loan Repayment Period is required when Loan Permitted is Yes."
      }
    }
  ],
  "validation_rules": [
    {
    "field": "employerEin",
    "rules": [
      {
        "type": "pattern",
        "value": "^\\d{2}-\\d{7}$",
        "message": "Employer EIN must be in ##-####### format."
      }
    ]
  },

  {
    "field": "planNumber",
    "rules": [
      {
        "type": "pattern",
        "value": "^\\d{3}$",
        "message": "Plan Number must be 3 digits."
      }
    ]
  },

  {
    "field": "planEffectiveDate",
    "rules": [
      {
        "type": "pattern",
        "value": "^\\d{1,2}/\\d{1,2}/\\d{4}$",
        "message": "Plan Effective Date must be in MM/DD/YYYY format."
      }
    ]
  },

  {
    "field": "employeeContributionPercentage",
    "rules": [
      {
        "type": "min",
        "value": 0,
        "message": "Employee Contribution Percentage cannot be less than 0%."
      },
      {
        "type": "max",
        "value": 100,
        "message": "Employee Contribution Percentage cannot be greater than 100%."
      }
    ]
  },

  {
    "field": "defaultAutomaticEnrollmentPercentage",
    "rules": [
      {
        "type": "min",
        "value": 0,
        "message": "Default Automatic Enrollment Percentage cannot be less than 0%."
      },
      {
        "type": "max",
        "value": 100,
        "message": "Default Automatic Enrollment Percentage cannot be greater than 100%."
      }
    ]
  },

  {
    "field": "loanPermitted",
    "rules": [
      {
        "type": "options",
        "value": ["Yes", "No"],
        "message": "Loan Permitted must be Yes or No."
      }
    ]
  },

  {
    "field": "automaticAnnualIncreaseEnabled",
    "rules": [
      {
        "type": "options",
        "value": ["Yes", "No"],
        "message": "Automatic Annual Increase Enabled must be Yes or No."
      }
    ]
  },

  {
    "field": "contributionType",
    "rules": [
      {
        "type": "options",
        "value": [
          "Traditional Pre-Tax",
          "Roth After-Tax",
          "Traditional and Roth",
          "Employer Only",
          "Safe Harbor"
        ],
        "message": "Invalid Contribution Type."
      }
    ]
  },

  {
    "field": "automaticEnrollmentType",
    "rules": [
      {
        "type": "options",
        "value": [
          "None",
          "Automatic Contribution Arrangement",
          "Eligible Automatic Contribution Arrangement",
          "Qualified Automatic Contribution Arrangement"
        ],
        "message": "Invalid Automatic Enrollment Type."
      }
    ]
  },

  {
    "field": "vestingSchedule",
    "rules": [
      {
        "type": "options",
        "value": [
          "Immediate Vesting",
          "3-Year Cliff",
          "6-Year Graded",
          "Custom Schedule"
        ],
        "message": "Invalid Vesting Schedule."
      }
    ]
  },

  {
    "field": "eligibilityRequirement",
    "rules": [
      {
        "type": "options",
        "value": [
          "Immediate Eligibility",
          "30 Days of Service",
          "60 Days of Service",
          "90 Days of Service",
          "1 Year of Service",
          "Custom Eligibility"
        ],
        "message": "Invalid Eligibility Requirement."
      }
    ]
  },

  {
    "field": "permittedWithdrawalTypes",
    "rules": [
      {
        "type": "options",
        "value": [
          "Hardship Withdrawal",
          "In-Service Withdrawal",
          "Required Minimum Distribution",
          "Rollover Withdrawal",
          "Termination Distribution"
        ],
        "message": "Invalid Permitted Withdrawal Type."
      }
    ]
  }
  ]
}